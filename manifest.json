{
  "manifest_version": 3,
  "name": "Hello Translate",
  "short_name": "HelloTranslate",
  "version": "0.2.0",
  "description": "Translate selected text with keyboard shortcuts or auto-translate selection using Google Translate and DeepL.",
  "minimum_chrome_version": "114",
  "homepage_url": "https://github.com/kazhuravlev/hello-translate",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Hello Translate",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://translation.googleapis.com/*",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+9",
        "mac": "Command+Shift+9"
      }
    }
  }
}
